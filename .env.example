NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Mettre "true" pour lire/écrire Supabase même en local (auth locale possible via LOCAL_AUTH)
NEXT_PUBLIC_USE_SUPABASE=false
# Mettre "false" pour désactiver le demoStore quand Supabase est configuré
NEXT_PUBLIC_DEMO_MODE=
AGENT_DEBUG_LOGS=true
AGENT_QUALIFICATION_TIMEOUT_MS=30000
# Vercel AI Gateway takes precedence when set.
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL_ID=openai/gpt-5-mini
# OpenRouter fallback.
AI_API_KEY=
AI_MODEL_ID=openai/gpt-oss-120b:free
NEXT_PUBLIC_APP_URL=http://localhost:3000
N8N_BASE_URL=
N8N_CUSTOMER_EMAIL_WEBHOOK=
N8N_SEND_QUOTE_WEBHOOK=
N8N_FOLLOWUP_WEBHOOK=
N8N_HUMAN_REVIEW_WEBHOOK=
N8N_DAILY_DIGEST_WEBHOOK=
N8N_WEBHOOK_SECRET=
RESEND_API_KEY=
ORS_API_KEY=
