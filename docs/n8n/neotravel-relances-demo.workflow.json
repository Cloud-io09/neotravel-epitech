{
  "name": "NeoTravel — Relances DEMO (toutes les minutes)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 1
            }
          ]
        }
      },
      "id": "d1111111-1111-4111-8111-111111111111",
      "name": "Every minute",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "REPLACE_WITH_YOUR_APP_URL/api/followups/send-due",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-neotravel-webhook-secret",
              "value": "REPLACE_WITH_N8N_WEBHOOK_SECRET"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{ \"limit\": 50 }",
        "options": {}
      },
      "id": "d2222222-2222-4222-8222-222222222222",
      "name": "Send due followups",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 300]
    }
  ],
  "connections": {
    "Every minute": {
      "main": [
        [{ "node": "Send due followups", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "active": false
