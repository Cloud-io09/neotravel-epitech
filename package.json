{
  "name": "neotravel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:supabase": "npx supabase start",
    "db:reset": "npx supabase db reset",
    "db:seed": "npx tsx scripts/seed-demo-data.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "create-admin": "npx --yes tsx scripts/create-admin.ts",
    "set-local-admin": "npx --yes tsx scripts/set-local-admin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "set -a; eval \"$(supabase status -o env)\"; set +a; RUN_SUPABASE_INTEGRATION=true vitest run src/lib/quotes/quote-service.integration.test.ts src/lib/ai/create-or-update-lead.integration.test.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.74",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "ai": "^6.0.209",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "openai": "^4.77.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.15",
    "supabase": "^2.108.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
